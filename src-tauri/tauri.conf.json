{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "minimal-browser",
  "version": "0.1.0",
  "identifier": "light-browser",

  "build": {
    "frontendDist": "../src"
  },

  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "minimal-browser",
        "width": 800,
        "height": 600,
        "resizable": true,
        "devtools": false,
        "fileDropEnabled": false
      }
    ],
    "security": {
      "csp": null
    }
  },

  "bundle": {
  "active": true,
  "targets": ["deb"],
  "linux": {
    "deb": {
      "depends": [
        "libwebkit2gtk-4.1-0",
        "libgtk-3-0"
      ]
    }
  }
}
